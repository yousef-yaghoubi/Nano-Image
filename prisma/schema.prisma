generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}



model Prompts {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  prompt      String?
  image       String
  likes       Int
  layout      String
  creatorName String
  model       String
  notes       String?
  tags        String[]
  isPremium   Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  favorites   PromptFavorite[]
}

model Users {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  clerkId   String    @unique
  email     String
  role      Role      @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  image     String?
  waitForSuperAdmin Boolean @default(false)
  favorite  Favorite?
}

model Favorite {
  id      String           @id @default(auto()) @map("_id") @db.ObjectId
  user    Users            @relation(fields: [userId], references: [id])
  userId  String           @unique @db.ObjectId
  prompts PromptFavorite[]
}

model PromptFavorite {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  prompt     Prompts  @relation(fields: [promptId], references: [id])
  promptId   String   @db.ObjectId
  favorite   Favorite @relation(fields: [favoriteId], references: [id])
  favoriteId String   @db.ObjectId
}

enum Role {
  MEMBER
  ADMIN
  SUPER_ADMIN
}