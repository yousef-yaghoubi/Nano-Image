generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


model Prompts {
 id             String           @id @default(auto()) @map("_id") @db.ObjectId
  title String
  prompt String?
  image String
  likes Int
  layout String
  creatorName String
  model String
  notes String?
  tags String[]
  isLiked Boolean
  isPremium Boolean
}
